OPENCLAW_DB_PATH=data/governance.db
# Optional PostgreSQL override. If set, this wins over OPENCLAW_DB_PATH.
# OPENCLAW_DATABASE_URL=postgresql+psycopg://openclaw:change-me@127.0.0.1:5432/openclaw_governance
OPENCLAW_SECRET_KEY=replace-with-generated-secret
GOVERNANCE_ADMIN_TOKEN=replace-with-generated-token
OPENCLAW_UI_HOST=127.0.0.1
OPENCLAW_UI_PORT=8899
OPENCLAW_PROXY_HOST=127.0.0.1
OPENCLAW_PROXY_PORT=8888
OPENCLAW_SESSION_COOKIE_SECURE=false
OPENCLAW_DEBUG_WS_SNIPPETS=false
OPENCLAW_DESKTOP_NOTIFICATIONS=false
